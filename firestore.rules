rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Analytics-loggar: Alla kan skriva, admin-dashboardet kan läsa
    match /app_analytics/{document} {
      allow create: if true;
      allow read: if true;
      allow update, delete: if false;
    }

    // 2. Övriga samlingar: Tillåt alla att läsa/skriva fritt (eftersom appen hanterar inloggning manuellt)
    match /tips/{document} {
      allow read, write: if true;
    }
    match /matches/{document} {
      allow read, write: if true;
    }
    match /chat/{document} {
      allow read, write: if true;
    }
    match /settings/{document} {
      allow read, write: if true;
    }
    match /hallOfFame/{document} {
      allow read, write: if true;
    }
  }
}
